{
  "builds": [
    { "src": "api/quote.cjs", "use": "@vercel/node" },
    { "src": "api/index.py", "use": "@vercel/python" },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/quote", "dest": "api/quote.cjs" },
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
